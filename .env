# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# App Mode: "development" = dummy DB (postgres) + simulated data
#            "production"  = production DB (zorbitads_production) + real Modash API
APP_MODE=development

# Database (auto-selects DB based on APP_MODE unless DB_NAME is explicitly set)
# development -> postgres | production -> zorbitads_production
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kalyankumardatta
DB_PASSWORD=
# Local / synthetic dataset (postgres DB + zorbitads schema; not production)
DB_NAME=postgres
DB_SCHEMA=zorbitads
DB_SYNCHRONIZE=false
DB_LOGGING=true

# JWT
JWT_SECRET=socialtweebs-secret-key-change-in-production-2024
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Frontend URL
FRONTEND_URL=http://localhost:3001

# SMTP Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@socialtweebs.com

# Modash API Integration
# Auto-enabled when APP_MODE=production. Override with explicit true/false.
# MODASH_ENABLED=true
MODASH_API_URL=https://api.modash.io/v1
MODASH_RAW_API_URL=https://api.modash.io/v1
MODASH_API_KEY=0BfnoYnvcfvybRElnSFzJeRFrWxAjUVm
