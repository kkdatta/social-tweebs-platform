# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kalyankumardatta
DB_PASSWORD=
DB_NAME=postgres
DB_SCHEMA=zorbitads
DB_SYNCHRONIZE=false
DB_LOGGING=true

# JWT
JWT_SECRET=socialtweebs-secret-key-change-in-production-2024
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Modash API Integration
# Set to "true" to enable live Modash API calls
# Set to "false" to use local database only (no credits charged, good for testing)
MODASH_ENABLED=false
MODASH_API_URL=https://api.modash.io/v1
MODASH_API_KEY=your_modash_api_key_here
